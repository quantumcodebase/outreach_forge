# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/cold_email_cockpit

# 32-byte key encoded in base64 (required)
# Example generator:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# IONOS defaults
IONOS_IMAP_HOST=imap.ionos.com
IONOS_IMAP_PORT=993
IONOS_SMTP_HOST=smtp.ionos.com
IONOS_SMTP_PORT=587

# Safety defaults
OUTBOUND_MODE=dry_run
NEXT_PUBLIC_OUTBOUND_MODE=dry_run
