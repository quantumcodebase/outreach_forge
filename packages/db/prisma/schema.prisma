generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmailAccountStatus {
  active
  paused
  error
}

enum LeadStatus {
  active
  suppressed
}

enum SuppressionReason {
  bounce_hard
  unsubscribe
  manual
  complaint
}

enum CampaignStatus {
  draft
  active
  paused
  finished
}

enum EnrollmentStatus {
  active
  replied
  bounced
  unsubscribed
  finished
  paused
}

enum MessageDirection {
  sent
  received
}

enum EventType {
  sent
  bounce_hard
  bounce_soft
  reply
  unsubscribe
  open
}

model email_accounts {
  id                   String             @id @default(uuid()) @db.Uuid
  label                String             @db.Text
  imap_host            String             @db.Text
  imap_port            Int
  imap_user            String             @db.Text
  smtp_host            String             @db.Text
  smtp_port            Int
  smtp_user            String             @db.Text
  encrypted_pass       String             @db.Text
  daily_cap            Int                @default(50)
  sending_window_start DateTime           @db.Time(6)
  sending_window_end   DateTime           @db.Time(6)
  timezone             String             @db.Text
  status               EmailAccountStatus
  last_synced_at       DateTime?          @db.Timestamptz(6)
  last_uid_synced      BigInt?
  bounce_count         Int                @default(0)
  reply_count          Int                @default(0)
  created_at           DateTime           @default(now()) @db.Timestamptz(6)

  campaigns campaigns[]
  messages  messages[]
}

model leads {
  id            String           @id @default(uuid()) @db.Uuid
  email         String           @unique @db.Text
  first_name    String?          @db.Text
  last_name     String?          @db.Text
  company       String?          @db.Text
  title         String?          @db.Text
  city          String?          @db.Text
  tags          String[]
  custom_fields Json
  status        LeadStatus
  created_at    DateTime         @default(now()) @db.Timestamptz(6)

  enrollments enrollments[]
  events      events[]
}

model suppression_list {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @db.Text
  reason             SuppressionReason
  source_campaign_id String?            @db.Uuid
  added_at           DateTime           @default(now()) @db.Timestamptz(6)

  source_campaign campaigns? @relation(fields: [source_campaign_id], references: [id])

  @@index([email])
}

model campaigns {
  id                   String            @id @default(uuid()) @db.Uuid
  name                 String            @db.Text
  from_account_id      String            @db.Uuid
  daily_cap            Int
  sending_window_start DateTime          @db.Time(6)
  sending_window_end   DateTime          @db.Time(6)
  timezone             String            @db.Text
  status               CampaignStatus
  created_at           DateTime          @default(now()) @db.Timestamptz(6)

  from_account     email_accounts    @relation(fields: [from_account_id], references: [id])
  steps            steps[]
  enrollments      enrollments[]
  events           events[]
  suppression_list suppression_list[]
}

model steps {
  id               String      @id @default(uuid()) @db.Uuid
  campaign_id      String      @db.Uuid
  step_number      Int
  subject_template String      @db.Text
  body_template    String      @db.Text
  delay_days       Int

  campaign campaigns @relation(fields: [campaign_id], references: [id])
  messages messages[]

  @@unique([campaign_id, step_number])
}

model enrollments {
  id           String           @id @default(uuid()) @db.Uuid
  lead_id      String           @db.Uuid
  campaign_id  String           @db.Uuid
  current_step Int
  status       EnrollmentStatus
  enrolled_at  DateTime         @default(now()) @db.Timestamptz(6)
  last_sent_at DateTime?        @db.Timestamptz(6)
  next_send_at DateTime?        @db.Timestamptz(6)
  thread_id    String?          @db.Text

  lead      leads     @relation(fields: [lead_id], references: [id])
  campaign  campaigns @relation(fields: [campaign_id], references: [id])
  messages  messages[]
  events    events[]

  @@unique([lead_id, campaign_id])
}

model messages {
  id                String           @id @default(uuid()) @db.Uuid
  enrollment_id     String?          @db.Uuid
  step_id           String?          @db.Uuid
  account_id        String           @db.Uuid
  direction         MessageDirection
  message_id_header String?          @db.Text
  in_reply_to       String?          @db.Text
  references_header String?          @db.Text
  thread_id         String?          @db.Text
  subject           String?          @db.Text
  body_preview      String?          @db.VarChar(300)
  sent_at           DateTime?        @db.Timestamptz(6)
  received_at       DateTime?        @db.Timestamptz(6)

  enrollment enrollments?   @relation(fields: [enrollment_id], references: [id])
  step       steps?         @relation(fields: [step_id], references: [id])
  account    email_accounts @relation(fields: [account_id], references: [id])

  @@index([message_id_header])
  @@index([thread_id])
}

model events {
  id            String    @id @default(uuid()) @db.Uuid
  lead_id       String?   @db.Uuid
  campaign_id   String?   @db.Uuid
  enrollment_id String?   @db.Uuid
  type          EventType
  metadata      Json
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  lead       leads?       @relation(fields: [lead_id], references: [id])
  campaign   campaigns?   @relation(fields: [campaign_id], references: [id])
  enrollment enrollments? @relation(fields: [enrollment_id], references: [id])

  @@index([type, created_at])
}

model wlr_runs {
  run_id         String    @id @db.Text
  project_id     String?   @db.Text
  status         String?   @db.Text
  started_at     DateTime? @db.Timestamptz(6)
  ended_at       DateTime? @db.Timestamptz(6)
  discovered     Int?
  enriched       Int?
  deduped        Int?
  error          String?   @db.Text
  notes          String?   @db.Text
  raw            Json
  last_synced_at DateTime  @default(now()) @db.Timestamptz(6)

  @@index([project_id, started_at])
  @@index([status, started_at])
}

model wlr_search_recipes {
  id                    String    @id @default(uuid()) @db.Uuid
  project_id            String    @db.Text
  name                  String    @db.Text
  offer_name            String    @db.Text
  offer_type            String    @db.Text
  icp_label             String    @db.Text
  workflow_label        String    @db.Text
  geography_label       String    @db.Text
  cadence_type          String    @db.Text
  enabled               Boolean   @default(false)
  confidence_threshold  Int       @default(60)
  lead_cap              Int       @default(200)
  settings_json         Json
  lifecycle_status      String?   @db.Text
  pending_run_id        String?   @db.Text
  pending_run_started_at DateTime? @db.Timestamptz(6)
  last_synced_source_run_id String? @db.Text
  next_run_at           DateTime? @db.Timestamptz(6)
  last_scheduled_run_at DateTime? @db.Timestamptz(6)
  last_run_origin       String?   @db.Text
  last_success_at       DateTime? @db.Timestamptz(6)
  last_failure_at       DateTime? @db.Timestamptz(6)
  last_failure_message  String?   @db.Text
  last_run_at           DateTime? @db.Timestamptz(6)
  last_sync_at          DateTime? @db.Timestamptz(6)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)
  updated_at            DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([project_id, name])
  @@index([project_id, enabled])
}

model wlr_sync_state {
  id                 String    @id @default(uuid()) @db.Uuid
  project_id         String    @db.Text
  recipe_id          String?   @db.Uuid
  last_synced_run_id String?   @db.Text
  last_synced_at     DateTime? @db.Timestamptz(6)
  last_created_count Int       @default(0)
  last_updated_count Int       @default(0)
  last_skipped_count Int       @default(0)
  updated_at         DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([project_id, recipe_id])
  @@index([project_id, last_synced_at])
}

model wlr_scheduler_state {
  project_id      String   @id @db.Text
  last_tick_at    DateTime? @db.Timestamptz(6)
  last_tick_ok    Boolean   @default(true)
  last_error      String?   @db.Text
  updated_at      DateTime  @updatedAt @db.Timestamptz(6)
}

model lead_qualification {
  id                   String   @id @default(uuid()) @db.Uuid
  lead_id               String   @unique @db.Uuid
  project_id            String   @db.Text
  recipe_id             String?  @db.Uuid
  signal_scope          String   @db.Text
  pain_signal           String?  @db.Text
  change_signal         String?  @db.Text
  buildability_fit      String?  @db.Text
  stakeholder_label     String?  @db.Text
  proposed_wedge        String?  @db.Text
  pain_score            Int      @default(0)
  workflow_score        Int      @default(0)
  buying_motion_score   Int      @default(0)
  buildability_score    Int      @default(0)
  stakeholder_score     Int      @default(0)
  total_score           Int      @default(0)
  qualification_status  String   @default("nurture") @db.Text
  rationale_notes       String?  @db.Text
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @updatedAt @db.Timestamptz(6)

  @@index([project_id, qualification_status])
  @@index([signal_scope, total_score])
}
